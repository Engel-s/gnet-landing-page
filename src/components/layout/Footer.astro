---
import { Icon } from "astro-icon/components";

const year = new Date().getFullYear();
const githubUrl = "https://github.com/centeno2/Gnet_System";

const links = [
  {
    label: "Problemas",
    href: "#problemas",
  },
  {
    label: "Video",
    href: "#video",
  },
  {
    label: "Tecnologías",
    href: "#tecnologias",
  },
];
---

<footer class="relative w-full overflow-hidden border-t border-white/70 bg-white/65 px-6 py-12 shadow-[0_-20px_60px_rgba(26,43,66,0.08)] backdrop-blur-xl lg:px-10">
  <div class="footer-orb footer-orb-one"></div>
  <div class="footer-orb footer-orb-two"></div>

  <div class="footer-glow-line"></div>

  <div
    data-scroll-card
    class="relative z-10 mx-auto max-w-7xl"
  >
    <div class="grid gap-10 lg:grid-cols-[1.2fr_0.8fr_0.8fr] lg:items-start">
      <div>
        <div class="flex items-center gap-4">
          <div
            class="footer-mark grid size-14 place-items-center rounded-2xl bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-secondary)] text-xl font-black text-white shadow-xl shadow-blue-950/20"
          >
            G
          </div>

          <div>
            <p class="text-2xl font-black tracking-tight text-[var(--color-text)]">
              Gnet System
            </p>

            <p class="mt-1 text-sm font-bold uppercase tracking-[0.18em] text-[var(--color-secondary)]">
              Gestión comercial inteligente
            </p>
          </div>
        </div>

        <p class="mt-5 max-w-xl text-sm leading-7 text-[var(--color-muted)] sm:text-base">
          Sistema web orientado a mejorar los procesos de ventas, inventario,
          caja, créditos institucionales y reportes dentro de Tienda Gnet.
        </p>
      </div>

      <div>
        <p class="text-sm font-black uppercase tracking-[0.18em] text-[var(--color-primary)]">
          Navegación
        </p>

        <nav class="mt-4 flex flex-col gap-3">
          {
            links.map((link) => (
              <a
                href={link.href}
                class="footer-link w-fit text-sm font-bold text-[var(--color-muted)]"
              >
                {link.label}
              </a>
            ))
          }
        </nav>
      </div>

      <div>
        <p class="text-sm font-black uppercase tracking-[0.18em] text-[var(--color-primary)]">
          Stack principal
        </p>

        <div class="mt-4 flex flex-wrap gap-2">
          <span class="footer-badge">Laravel</span>
          <span class="footer-badge">Livewire</span>
          <span class="footer-badge">MaryUI</span>
          <span class="footer-badge">MySQL</span>
        </div>
      </div>
    </div>

    <div
      class="mt-10 flex flex-col gap-4 border-t border-[var(--color-bg-soft)] pt-6 text-sm text-[var(--color-muted)] sm:flex-row sm:items-center sm:justify-between"
    >
      <p>
        © {year} · Proyecto académico
      </p>

      <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-cta hero-cta-github"
          aria-label="Ver repositorio de Gnet System en GitHub"
        >
          <span class="hero-cta-icon">
            <Icon name="simple-icons:github" class="size-5" />
          </span>

          <span class="hero-cta-text">
            GNET-System
          </span>
        </a>

        <a
          href="#"
          class="footer-top-link inline-flex w-fit items-center gap-2 rounded-full border border-[var(--color-bg-soft)] bg-white/70 px-4 py-3 text-sm font-black text-[var(--color-primary)] transition hover:border-[var(--color-secondary)] hover:bg-white"
        >
          Volver arriba
          <span>↑</span>
        </a>
      </div>
    </div>
  </div>
</footer>