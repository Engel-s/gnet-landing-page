---
import { Icon } from "astro-icon/components";
import { teamMembers } from "../../data/team";
---

<section id="equipo" class="px-6 py-16 lg:px-10">
  <div class="mx-auto max-w-7xl">
    <div data-scroll-card class="text-center">
      <h2 class="text-3xl font-black tracking-tight text-[var(--color-primary)] sm:text-4xl">
        Equipo desarrollador
      </h2>

      <p class="mx-auto mt-4 max-w-2xl text-sm leading-7 text-[var(--color-text)] sm:text-base">
        Integrantes que participaron en el análisis, diseño, programación y construcción de Gnet System.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
      {
        teamMembers.map((member) => (
          <article data-scroll-card class="team-card group">
            <div class="team-photo-wrap">
              <img
                src={member.image}
                alt={`Foto de ${member.name}`}
                class="team-photo"
                loading="lazy"
              />

              <div class="team-overlay">
                <div class="team-overlay-icon">
                  <Icon name={member.icon} class="size-6" />
                </div>

                <p class="team-description">
                  {member.description}
                </p>
              </div>
            </div>

            <div class="pt-5 text-center">
              <h3 class="text-lg font-black leading-tight text-[var(--color-text)]">
                {member.name}
              </h3>

              <p class="mt-2 text-sm font-black text-[var(--color-secondary)]">
                {member.role}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>