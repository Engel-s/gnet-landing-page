---
import { Icon } from "astro-icon/components";
import { showcaseItems } from "../../data/showcase";

const githubUrl = "https://github.com/centeno2/Gnet_System";

const heroCopyByTitle: Record<
  string,
  {
    heading: string;
    description: string;
  }
> = {
  "Panel principal": {
    heading: "Panel principal para acceder rápidamente a los módulos del sistema.",
    description:
      "Desde esta pantalla se centraliza la navegación hacia ventas, inventario, caja, clientes, reportes y las áreas principales de Gnet System.",
  },
  Login: {
    heading: "Inicio de sesión seguro para usuarios autorizados.",
    description:
      "El acceso al sistema se controla mediante credenciales, permitiendo que cada usuario ingrese según su rol y permisos asignados.",
  },
  Facturación: {
    heading: "Facturación ágil para ventas, productos y servicios.",
    description:
      "Permite registrar ventas al contado o crédito, agregar productos, servicios, pagos y generar comprobantes de manera ordenada.",
  },
  Productos: {
    heading: "Control completo de productos, stock y garantías.",
    description:
      "Organiza productos, precios, existencias, series y garantías para mantener el inventario actualizado y reducir errores operativos.",
  },
  Compras: {
    heading: "Registro de compras para actualizar el inventario.",
    description:
      "Cada compra alimenta el stock de productos, guarda datos del proveedor y ayuda a controlar costos, cantidades y entradas al sistema.",
  },
  Créditos: {
    heading: "Seguimiento claro de créditos institucionales.",
    description:
      "Controla saldos pendientes, abonos, instituciones y estados de crédito para mejorar la recuperación y administración de cuentas.",
  },
  "Arqueo de caja": {
    heading: "Control de caja con aperturas, egresos y cierres.",
    description:
      "Ayuda a verificar el dinero disponible, registrar movimientos y comparar los montos esperados contra los montos físicos.",
  },
  Devoluciones: {
    heading: "Gestión de devoluciones y cambios de productos.",
    description:
      "Permite registrar devoluciones, validar condiciones y mantener trazabilidad sobre cambios, salidas y ajustes de inventario.",
  },
  "Instalación de cámaras": {
    heading: "Control de servicios de instalación de cámaras.",
    description:
      "Organiza contratos, materiales, mano de obra, anticipos y saldos pendientes asociados a instalaciones realizadas por la tienda.",
  },
  "Servicio técnico": {
    heading: "Seguimiento de trabajos y servicios técnicos.",
    description:
      "Facilita registrar diagnósticos, responsables, costos y detalles de servicios técnicos para mejorar el control operativo.",
  },
  "Otras salidas": {
    heading: "Registro de salidas de inventario no asociadas a ventas.",
    description:
      "Controla movimientos como uso interno, daños, pérdidas o ajustes, evitando que el inventario se modifique sin justificación.",
  },
  "Gestión de planilla": {
    heading: "Administración de pagos y periodos de planilla.",
    description:
      "Permite gestionar trabajadores, cortes de pago, cálculos y comprobantes relacionados con la planilla del personal.",
  },
  Reportes: {
    heading: "Informes para análisis y toma de decisiones.",
    description:
      "Genera reportes de ventas, inventario, créditos, compras, caja y otros procesos importantes para evaluar el funcionamiento de la tienda.",
  },
  Mantenimiento: {
    heading: "Herramientas para respaldo y mantenimiento del sistema.",
    description:
      "Incluye funciones orientadas a proteger la información y apoyar tareas técnicas como respaldos o restauración de datos.",
  },
  "Acerca de": {
    heading: "Información del proyecto y del equipo desarrollador.",
    description:
      "Presenta los datos generales de Gnet System, su propósito académico y los integrantes responsables de su construcción.",
  },
};

const heroItems = showcaseItems.map((item) => ({
  ...item,
  heading: heroCopyByTitle[item.title]?.heading ?? item.title,
  heroDescription: heroCopyByTitle[item.title]?.description ?? item.description,
}));

const initialItem = heroItems[0];
---

<section class="relative min-h-screen overflow-hidden px-6 pt-10 pb-16 lg:px-10 lg:pt-8 lg:pb-20">
  <div
    class="mx-auto grid min-h-[calc(100vh-5rem)] max-w-7xl items-center gap-10 xl:gap-20 lg:grid-cols-[0.78fr_1.22fr]"
  >
    <div data-reveal class="relative z-20 order-1 max-w-2xl lg:-translate-y-4">
      <div class="space-y-6">
        <div>
          <p
            class="mb-3 text-sm font-black uppercase tracking-[0.28em] text-[var(--color-secondary)]"
          >
            Sistema web de gestión comercial
          </p>

          <h1
            class="text-5xl font-black leading-none tracking-tight sm:text-6xl xl:text-7xl"
          >
            <span
              class="block bg-gradient-to-r from-[var(--color-primary)] via-[var(--color-secondary)] to-[#2e8bc0] bg-clip-text text-transparent"
            >
              Gnet System
            </span>
          </h1>

          <div
            class="mt-5 h-1.5 w-28 rounded-full bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-secondary)]"
          >
          </div>
        </div>

        <div
          data-hero-copy
          class="hero-dynamic-copy hero-copy-panel"
          aria-live="polite"
        >
          <p
            id="hero-current-module"
            class="hero-copy-module"
          >
            {initialItem.title}
          </p>

          <h2
            id="hero-dynamic-heading"
            class="hero-copy-title"
          >
            {initialItem.heading}
          </h2>

          <p
            id="hero-dynamic-description"
            class="hero-copy-description"
          >
            {initialItem.heroDescription}
          </p>
        </div>
      </div>

      <div class="mt-9 hidden gap-3 lg:flex lg:flex-wrap lg:items-center">
        <a href="#video" class="hero-cta hero-cta-primary">
          <span class="hero-cta-icon">
            <Icon name="lucide:play" class="size-5" />
          </span>

          <span class="hero-cta-text">
            Video
          </span>
        </a>

        <a href="#tecnologias" class="hero-cta hero-cta-soft">
          <span class="hero-cta-icon">
            <Icon name="lucide:blocks" class="size-5" />
          </span>

          <span class="hero-cta-text">
            Tecnologías
          </span>
        </a>

        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-cta hero-cta-github"
          aria-label="Ver repositorio de Gnet System en GitHub"
        >
          <span class="hero-cta-icon">
            <Icon name="simple-icons:github" class="size-5" />
          </span>

          <span class="hero-cta-text">
            GNET-System
          </span>
        </a>
      </div>
    </div>

    <div
      data-coverflow-root
      data-reveal
      class="relative z-10 order-2 w-full min-w-0 overflow-visible lg:-translate-y-3"
    >
      <div
        class="pointer-events-none absolute -left-10 top-8 h-56 w-56 rounded-full bg-[var(--color-secondary)]/20 blur-3xl"
      >
      </div>

      <div
        class="pointer-events-none absolute right-0 bottom-12 h-72 w-72 rounded-full bg-[var(--color-primary)]/16 blur-3xl"
      >
      </div>

      <div class="coverflow">
        <div class="coverflow-stage">
          {
            heroItems.map((item, index) => (
              <button
                type="button"
                data-coverflow-slide
                data-title={item.title}
                data-heading={item.heading}
                data-description={item.heroDescription}
                class="coverflow-slide"
                aria-label={`Mostrar captura de ${item.title}`}
              >
                <span class="coverflow-card">
                  <img
                    src={item.image}
                    alt={`Captura de ${item.title} en Gnet System`}
                    loading={index === 0 ? "eager" : "lazy"}
                    draggable="false"
                  />

                  <span class="coverflow-fade"></span>
                </span>
              </button>
            ))
          }
        </div>
      </div>
    </div>

    <div
      data-reveal
      class="order-3 grid gap-3 sm:flex sm:flex-wrap sm:justify-center lg:hidden"
    >
      <a href="#video" class="hero-cta hero-cta-primary">
        <span class="hero-cta-icon">
          <Icon name="lucide:play" class="size-5" />
        </span>

        <span class="hero-cta-text">
          Video
        </span>
      </a>

      <a href="#tecnologias" class="hero-cta hero-cta-soft">
        <span class="hero-cta-icon">
          <Icon name="lucide:blocks" class="size-5" />
        </span>

        <span class="hero-cta-text">
          Tecnologías
        </span>
      </a>

      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="hero-cta hero-cta-github"
        aria-label="Ver repositorio de Gnet System en GitHub"
      >
        <span class="hero-cta-icon">
          <Icon name="simple-icons:github" class="size-5" />
        </span>

        <span class="hero-cta-text">
          GNET-System
        </span>
      </a>
    </div>
  </div>
</section>

<script>
  const root = document.querySelector<HTMLElement>("[data-coverflow-root]");
  const heroCopy = document.querySelector<HTMLElement>("[data-hero-copy]");
  const moduleTitle = document.querySelector<HTMLElement>("#hero-current-module");
  const heading = document.querySelector<HTMLElement>("#hero-dynamic-heading");
  const description = document.querySelector<HTMLElement>("#hero-dynamic-description");

  if (root) {
    const slides = Array.from(
      root.querySelectorAll<HTMLButtonElement>("[data-coverflow-slide]"),
    );

    let activeIndex = 0;
    let currentTextIndex = -1;
    let autoplayId: number | undefined;
    let textTimeoutId: number | undefined;

    const getDistance = (index: number, active: number, total: number) => {
      let distance = index - active;

      if (distance > total / 2) {
        distance -= total;
      }

      if (distance < -total / 2) {
        distance += total;
      }

      return distance;
    };

    const updateHeroText = (index: number, animate = true) => {
      if (currentTextIndex === index) return;

      const slide = slides[index];

      if (!slide || !moduleTitle || !heading || !description) return;

      const nextTitle = slide.dataset.title ?? "";
      const nextHeading = slide.dataset.heading ?? "";
      const nextDescription = slide.dataset.description ?? "";

      currentTextIndex = index;

      const applyText = () => {
        moduleTitle.textContent = nextTitle;
        heading.textContent = nextHeading;
        description.textContent = nextDescription;
      };

      if (!animate || !heroCopy) {
        applyText();
        return;
      }

      if (textTimeoutId) {
        window.clearTimeout(textTimeoutId);
      }

      heroCopy.classList.add("is-changing");

      textTimeoutId = window.setTimeout(() => {
        applyText();
        heroCopy.classList.remove("is-changing");
      }, 180);
    };

    const renderCoverflow = (animateText = true) => {
      const total = slides.length;

      slides.forEach((slide, index) => {
        const distance = getDistance(index, activeIndex, total);

        slide.classList.remove(
          "is-active",
          "is-left-one",
          "is-right-one",
          "is-left-two",
          "is-right-two",
          "is-left-three",
          "is-right-three",
          "is-hidden",
        );

        if (distance === 0) {
          slide.classList.add("is-active");
        } else if (distance === -1) {
          slide.classList.add("is-left-one");
        } else if (distance === 1) {
          slide.classList.add("is-right-one");
        } else if (distance === -2) {
          slide.classList.add("is-left-two");
        } else if (distance === 2) {
          slide.classList.add("is-right-two");
        } else if (distance === -3) {
          slide.classList.add("is-left-three");
        } else if (distance === 3) {
          slide.classList.add("is-right-three");
        } else {
          slide.classList.add("is-hidden");
        }
      });

      updateHeroText(activeIndex, animateText);
    };

    const startAutoplay = () => {
      autoplayId = window.setInterval(() => {
        activeIndex = (activeIndex + 1) % slides.length;
        renderCoverflow();
      }, 3400);
    };

    slides.forEach((slide, index) => {
      slide.addEventListener("click", () => {
        activeIndex = index;
        renderCoverflow();

        if (autoplayId) {
          window.clearInterval(autoplayId);
        }

        startAutoplay();
      });
    });

    renderCoverflow(false);
    startAutoplay();
  }
</script>