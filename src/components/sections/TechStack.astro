---
import { Icon } from "astro-icon/components";
import { technologies } from "../../data/technologies";
---

<section id="tecnologias" class="px-6 py-16 lg:px-10">
  <div class="mx-auto max-w-7xl overflow-hidden">
    <div data-scroll-card class="text-center">
      <h2 class="mt-3 text-3xl font-black tracking-tight text-[var(--color-primary)] sm:text-4xl">
        Stack tecnológico de Gnet System
      </h2>

      <p class="mx-auto mt-4 max-w-2xl text-sm leading-7 text-[var(--color-text)] sm:text-base">
        Herramientas utilizadas para construir un sistema moderno, mantenible y orientado a procesos reales.
      </p>
    </div>

    <div
      data-scroll-card
      class="relative mt-12 overflow-hidden py-8 [mask-image:linear-gradient(to_right,transparent,black_10%,black_90%,transparent)]"
    >
      <div class="tech-train flex w-max items-center gap-10">
        <div class="flex items-center gap-10">
          {
            technologies.map((tech) => (
              <article class="tech-stack-item">
                <div class="tech-stack-icon">
                  <Icon name={tech.icon} class="size-12 sm:size-14" />
                </div>

                <h3 class="tech-stack-name">
                  {tech.name}
                </h3>
              </article>
            ))
          }
        </div>

        <div class="flex items-center gap-10" aria-hidden="true">
          {
            technologies.map((tech) => (
              <article class="tech-stack-item">
                <div class="tech-stack-icon">
                  <Icon name={tech.icon} class="size-12 sm:size-14" />
                </div>

                <h3 class="tech-stack-name">
                  {tech.name}
                </h3>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>