---
import { Icon } from "astro-icon/components";
import { technologies } from "../../data/technologies";
---

<section id="tecnologias" class="px-6 py-16 lg:px-10">
  <div class="mx-auto max-w-7xl overflow-hidden">
    <div data-scroll-card class="text-center">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-[var(--color-primary)]">
        Tecnologías usadas
      </p>

      <h2 class="mt-3 text-3xl font-black tracking-tight text-[var(--color-text)] sm:text-4xl">
        Stack tecnológico de Gnet System
      </h2>

      <p class="mx-auto mt-4 max-w-2xl text-sm leading-7 text-[var(--color-muted)] sm:text-base">
        Herramientas utilizadas para construir un sistema moderno, mantenible y orientado a procesos reales.
      </p>
    </div>

    <div
      data-scroll-card
      class="relative mt-12 overflow-hidden py-4 [mask-image:linear-gradient(to_right,transparent,black_10%,black_90%,transparent)]"
    >
      <div class="tech-train flex w-max items-center gap-5">
        <div class="flex items-center gap-5">
          {
            technologies.map((tech) => (
              <article
                class="flex min-w-[210px] items-center gap-4 rounded-[1.25rem] border border-white/80 bg-white/75 px-5 py-4 shadow-lg shadow-blue-950/5 backdrop-blur"
              >
                <div
                  class="grid size-12 shrink-0 place-items-center rounded-2xl bg-[var(--color-bg-soft)] text-[var(--color-primary)]"
                >
                  <Icon name={tech.icon} class="size-6" />
                </div>

                <div>
                  <h3 class="text-sm font-black text-[var(--color-text)]">
                    {tech.name}
                  </h3>

                  <p class="text-xs font-semibold text-[var(--color-muted)]">
                    Gnet System
                  </p>
                </div>
              </article>
            ))
          }
        </div>

        <div class="flex items-center gap-5" aria-hidden="true">
          {
            technologies.map((tech) => (
              <article
                class="flex min-w-[210px] items-center gap-4 rounded-[1.25rem] border border-white/80 bg-white/75 px-5 py-4 shadow-lg shadow-blue-950/5 backdrop-blur"
              >
                <div
                  class="grid size-12 shrink-0 place-items-center rounded-2xl bg-[var(--color-bg-soft)] text-[var(--color-primary)]"
                >
                  <Icon name={tech.icon} class="size-6" />
                </div>

                <div>
                  <h3 class="text-sm font-black text-[var(--color-text)]">
                    {tech.name}
                  </h3>

                  <p class="text-xs font-semibold text-[var(--color-muted)]">
                    Gnet System
                  </p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>