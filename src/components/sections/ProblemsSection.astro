---
import { Icon } from "astro-icon/components";
import { problems } from "../../data/problems";
---

<section id="problemas" class="px-6 py-16 lg:px-10">
  <div class="mx-auto max-w-7xl">
    <div data-scroll-card class="max-w-2xl">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-[var(--color-primary)]">
        Problemas que aborda
      </p>

      <h2 class="mt-3 text-3xl font-black tracking-tight text-[var(--color-text)] sm:text-4xl">
        Gnet System nace para ordenar procesos clave de la tienda.
      </h2>

      <p class="mt-4 text-sm leading-7 text-[var(--color-muted)] sm:text-base">
        El sistema reduce procesos manuales y centraliza información importante para trabajar con más control.
      </p>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        problems.map((problem) => (
          <article
            data-scroll-card
            class="group rounded-[1.25rem] border border-white/80 bg-white/70 p-6 shadow-lg shadow-blue-950/5 backdrop-blur transition hover:-translate-y-1 hover:border-[var(--color-secondary)] hover:shadow-xl hover:shadow-blue-950/10"
          >
            <div
              class="grid size-12 place-items-center rounded-2xl bg-[var(--color-bg-soft)] text-[var(--color-primary)] transition group-hover:bg-[var(--color-primary)] group-hover:text-white"
            >
              <Icon name={problem.icon} class="size-6" />
            </div>

            <h3 class="mt-5 text-lg font-black text-[var(--color-text)]">
              {problem.title}
            </h3>

            <p class="mt-3 text-sm leading-6 text-[var(--color-muted)]">
              {problem.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>