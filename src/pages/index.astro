import VideoSection from "../components/sections/VideoSection.astro";
import TeamSection from "../components/sections/TeamSection.astro";
import TechStack from "../components/sections/TechStack.astro";
import Footer from "../components/layout/Footer.astro";
---

<Layout
  title="Gnet System | Gestión comercial inteligente"
  description="Landing informativa de Gnet System, sistema web para ventas, inventario, caja, créditos institucionales y reportes."
>
  <main class="gnet-animated-bg">
